def count_letter(str, letter):
    letter_count = 0
    for char in str:
        if char == letter:
            letter_count = letter_count + 1
    return letter_count

#compares two strings, returns number of characters in one with more
def compare_counts(str1, str2, letter):
    str_1_count = 0
    str_2_count = 0
    count_letter(str1, letter)
    str_1_count = count_letter(str1, letter)
    count_letter(str2, letter)
    str_2_count = count_letter(str2, letter)
    if str_1_count > str_2_count:
        return str_1_count
    if str_1_count < str_2_count:
        return str_2_count
    if str_1_count == str_2_count:
        return "Same"

