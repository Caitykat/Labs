#gets user input from string
def get_string():
    str = input("please enter a word or phrase")
    letter_count = 0
    for char in str:
        letter_count = letter_count + 1
    while letter_count < 10:
        str = input("please enter a word or phrase above 10 characters")
        letter_count = 0
        for char in str:
            letter_count = letter_count + 1
    return str.lower()



